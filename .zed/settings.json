{
	"lsp": {
		"luau-lsp": {
			"settings": {
				"roblox": {
					"enabled": false
				},
				"fflags": {
					"enable_by_default": true,
					"enable_new_solver": true,
					"sync": false,
					"override": {
						"DebugLuauUserDefinedClasses": "true"
					}
				},
				"luau-lsp": {
					"sourcemap": {
						"enabled": false,
						"autogenerate": false
					},
					"diagnostics": {
						"includeDependents": true,
						"workspace": true
					},
					"types": {
						"disabledGlobals": ["getfenv", "setfenv", "unpack", "loadstring"]
					},
					"completion": {
						"enabled": true,
						"imports": {
							"requireStyle": "AlwaysAbsolute",
							"separateGroupsWithLine": false,
							"useConst": true
						}
					},
					"index": {
						"enabled": true,
						"maxFiles": 10000
					}
				}
			}
		}
	},
	"languages": {
		"Luau": {
			"formatter": {
				"external": {
					"command": "stylua",
					"arguments": ["-"]
				}
			}
		},
		"TypeScript": {
			"formatter": "prettier"
		},
		"JSON": {
			"formatter": "prettier"
		},
		"JSONC": {
			"formatter": "prettier"
		}
	}
}
